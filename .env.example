# ── Proxmox ────────────────────────────────────────────────────
PROXMOX_HOST=https://192.168.1.100:8006
PROXMOX_TOKEN_ID=root@pam!monitoring
PROXMOX_TOKEN_SECRET=your-token-secret
PROXMOX_VERIFY_SSL=false

# pve-exporter uses separate user + token name (NOT the full token ID)
PVE_USER=root@pam
PVE_TOKEN_NAME=monitoring

# ── Unraid ─────────────────────────────────────────────────────
UNRAID_API_URL=http://192.168.1.101
UNRAID_API_KEY=your-unraid-api-key

# ── UniFi ──────────────────────────────────────────────────────
UNIFI_HOST=https://192.168.1.1
UNIFI_USERNAME=admin
UNIFI_PASSWORD=your-unifi-password
UNIFI_PORT=443
UNIFI_SITE=default

# ── Home Assistant ─────────────────────────────────────────────
HA_URL=http://192.168.1.102:8123
HA_TOKEN=your-long-lived-access-token
HA_NOTIFY_DEVICE=your_phone

# ── *arr (Sonarr/Radarr/Prowlarr) ─────────────────────────────
# Only configure the services you run
SONARR_URL=http://192.168.1.101:8989
SONARR_API_KEY=your-sonarr-api-key
RADARR_URL=http://192.168.1.101:7878
RADARR_API_KEY=your-radarr-api-key
PROWLARR_URL=http://192.168.1.101:9696
PROWLARR_API_KEY=your-prowlarr-api-key

# ── Pi-hole ───────────────────────────────────────────────────
PIHOLE_URL=http://192.168.1.53:8080
PIHOLE_PASSWORD=your-pihole-app-password

# ── Immich ─────────────────────────────────────────────────────
IMMICH_URL=http://192.168.1.103:2283
IMMICH_API_KEY=your-immich-api-key

# ── Grafana ────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# ── n8n ────────────────────────────────────────────────────────
N8N_USER=admin
N8N_PASSWORD=admin

# ── Network ────────────────────────────────────────────────────
# IP of the LXC running this stack (used for n8n webhook URL)
LXC_IP=192.168.1.50
